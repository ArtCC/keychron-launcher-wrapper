{
  "name": "keychron-launcher-wrapper",
  "version": "0.0.4",
  "description": "Minimal macOS Electron wrapper for the official Keychron Launcher with WebHID support.",
  "main": "src/main.js",
  "type": "commonjs",
  "author": "",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack:mac": "electron-builder --mac dir",
    "dist:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.keychron.launcherwrapper",
    "productName": "Keychron Launcher Wrapper",
    "files": [
      "assets/**/*",
      "src/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "mac": {
      "icon": "assets/keychron-launcher-wrapper.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}